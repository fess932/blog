---
import { NAV_LINKS, SITE_TITLE } from '../consts'
import ThemeToggle from './ThemeToggle.astro'
import Search from './Search.astro'

const pathname = Astro.url.pathname
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href)
---

<header
  class="sticky top-0 z-30 border-b border-zinc-200/70 bg-white/80 backdrop-blur dark:border-zinc-800/70 dark:bg-zinc-950/80"
>
  <nav class="mx-auto flex max-w-3xl items-center justify-between px-4 py-3 sm:px-6">
    <a href="/" class="font-mono text-lg font-bold tracking-tight text-zinc-900 dark:text-zinc-100">
      <span class="text-emerald-600 dark:text-emerald-400">~/</span>{SITE_TITLE}
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              'rounded-md px-2.5 py-1.5 text-sm font-medium transition-colors',
              isActive(link.href)
                ? 'text-emerald-600 dark:text-emerald-400'
                : 'text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100',
            ]}
          >
            {link.title}
          </a>
        ))
      }
      <Search />
      <ThemeToggle />
    </div>
  </nav>
</header>
