---
import { SOCIALS } from '../consts'

interface Props {
  class?: string
}
const { class: className = '' } = Astro.props

const links = [
  SOCIALS.email && { kind: 'mail', href: `mailto:${SOCIALS.email}`, label: 'Email' },
  SOCIALS.github && { kind: 'github', href: SOCIALS.github, label: 'GitHub' },
  SOCIALS.telegram && { kind: 'telegram', href: SOCIALS.telegram, label: 'Telegram' },
  SOCIALS.mastodon && { kind: 'mastodon', href: SOCIALS.mastodon, label: 'Mastodon' },
  SOCIALS.twitter && { kind: 'twitter', href: SOCIALS.twitter, label: 'Twitter' },
].filter(Boolean) as { kind: string; href: string; label: string }[]

