---

<div class:list={['flex items-center gap-4', className]}>
  {
    links.map((link) => (
      <a
        href={link.href}
        target={link.kind === 'mail' ? undefined : '_blank'}
        rel="noopener noreferrer"
        class="text-zinc-500 transition-colors hover:text-emerald-600 dark:text-zinc-400 dark:hover:text-emerald-400"
      >
        <span class="sr-only">{link.label}</span>
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d={paths[link.kind]} />
        </svg>
      </a>
    ))
  }
</div>
