---
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialIcons from "../components/SocialIcons.astro";
import { AUTHOR } from "../consts";
import { Content as Books } from "../content/books.md";
---

<BaseLayout title="About" description="About Ivan Cheremisin.">
    <div class="flex flex-col items-start gap-6 sm:flex-row sm:items-center">
        <img
            src={AUTHOR.avatar}
            alt={AUTHOR.name}
            class="h-24 w-24 rounded-full border border-zinc-200 object-cover dark:border-zinc-800"
        />
        <div>
            <h1
                class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100"
            >
                {AUTHOR.name}
            </h1>
            <p class="mt-1 text-zinc-600 dark:text-zinc-400">
                {AUTHOR.occupation}
            </p>
            <div class="mt-3">
                <SocialIcons />
            </div>
        </div>
    </div>

    <div
        class="mt-10 aspect-video w-full overflow-hidden rounded-xl border border-zinc-200 dark:border-zinc-800"
    >
        <iframe
            class="h-full w-full"
            src="https://www.youtube.com/embed/D87QQJqij5M"
            title="YouTube video player"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen></iframe>
    </div>

    <div class="prose mt-10">
        <p>
            I'm a software developer (prefer backend — Go, some Rust) who loves
            video games and rationality fiction.
        </p>
        <p>
            I mostly build small systems-y things and tools. A few of them live
            on the
            <a href="/projects">projects</a> page.
        </p>

        <ul>
            <li>
                using <a href="https://cloudinary.com/">cloudinary.com</a> for image
                hosting
            </li>
            <li>
                using <a href="https://dashboard.render.com"
                    >dashboard.render.com</a
                > for this static blog hosting
            </li>
            <li>
                good music for background and chill <a
                    href="https://www.lofi.cafe/">lofi.cafe</a>
            </li>
            <li>
                avatar generated by <a
                    href="https://www.vidnoz.com/ai-avatar-generator.html"
                    >vidnoz ai avatar generator</a
                >
            </li>
        </ul>

        <Books />
    </div>
</BaseLayout>
