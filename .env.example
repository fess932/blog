# Anytype sync (`bun run sync:anytype`)
# The Anytype desktop app must be running locally during sync.
ANYTYPE_API_KEY=          # Anytype → App Settings → API Keys → Create new
ANYTYPE_SPACE_ID=         # id of the space holding your posts
ANYTYPE_TYPE_NAME=Blog post  # type to pull (matched by display name)
# ANYTYPE_TYPE_KEY=       # ...or set the exact type key directly (skips name lookup)
# ANYTYPE_COLLECTION_ID=  # ...or pull a specific collection/list instead
# ANYTYPE_API_URL=http://127.0.0.1:31009
# ANYTYPE_API_VERSION=2025-11-08

# Cloudinary (images found in synced posts are re-hosted here)
CLOUDINARY_CLOUD_NAME=dvrzuu1gp
CLOUDINARY_UPLOAD_PRESET=  # create an *unsigned* upload preset in Cloudinary
